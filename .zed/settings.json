{
  // Input / Function
  "format_on_save": "on",
  "tab_size": 2,

  // File Scan/Search
  "file_scan_exclusions": [".git/", ".DS_Store", "dist/"],

  // Language / LSP
  "languages": {
    "HTML": {
      "formatter": [
        {
          "external": {
            "command": "pnpm",
            "arguments": ["oxfmt", "--stdin-filepath", "{buffer_path}"],
          },
        },
      ],
    },
    "JavaScript": {
      "language_servers": ["tsgo", "vtsls"],
      "formatter": [
        {
          "code_action": "source.fixAll.eslint",
        },
        {
          "external": {
            "command": "pnpm",
            "arguments": ["oxfmt", "--stdin-filepath", "{buffer_path}"],
          },
        },
      ],
    },
    "Svelte": {
      "formatter": [
        {
          "code_action": "source.fixAll.eslint",
        },
        {
          "external": {
            "command": "pnpm",
            "arguments": ["oxfmt", "--stdin-filepath", "{buffer_path}"],
          },
        },
      ],
    },
    "TypeScript": {
      "language_servers": ["tsgo", "vtsls"],
      "formatter": [
        {
          "code_action": "source.fixAll.eslint",
        },
        {
          "external": {
            "command": "pnpm",
            "arguments": ["oxfmt", "--stdin-filepath", "{buffer_path}"],
          },
        },
      ],
    },
  },
}
